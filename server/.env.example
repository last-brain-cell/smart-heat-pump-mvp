# =============================================================================
# Heat Pump Monitor - Environment Configuration
# =============================================================================
#
# Copy this file to .env and update values for your deployment
#
# IMPORTANT: Change all passwords before production deployment!
# =============================================================================

# -----------------------------------------------------------------------------
# InfluxDB Configuration (Time-Series Database)
# -----------------------------------------------------------------------------
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=heatpump123
INFLUXDB_ORG=heatpump
INFLUXDB_BUCKET=sensor_data
INFLUXDB_RETENTION=30d
INFLUXDB_TOKEN=heatpump-super-secret-token

# -----------------------------------------------------------------------------
# MQTT Broker Configuration
# -----------------------------------------------------------------------------
MQTT_USER=heatpump
MQTT_PASSWORD=heatpump123

# -----------------------------------------------------------------------------
# Domain & SSL Configuration (Production)
# -----------------------------------------------------------------------------
DOMAIN=heatpump.example.com
INFLUXDB_DOMAIN=data-explorer.heatpump.example.com
ACME_EMAIL=admin@example.com


mosquitto_pub -h 100.31.93.105 -p 1883 -u heatpump -P heatpump123 -t "test/hello" -m "it works"
mosquitto_pub -h 100.31.93.105 -p 1883 -u heatpump -P heatpump123 -t "test" -m "ping" -d